{
  "name": "expo-desktop-prebuild-config",
  "version": "1.0.19",
  "description": "Desktop-friendly Expo prebuild config",
  "keywords": [
    "android",
    "expo",
    "ios",
    "macos",
    "react native",
    "react native desktop",
    "windows"
  ],
  "homepage": "https://github.com/shirakaba/expo-desktop/tree/main/packages/expo-desktop-prebuild-config",
  "bugs": {
    "url": "https://github.com/shirakaba/expo-desktop/issues"
  },
  "license": "MIT",
  "author": "Jamie Birch <14055146+shirakaba@users.noreply.github.com> (https://github.com/shirakaba)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirakaba/expo-desktop.git",
    "directory": "packages/expo-desktop-prebuild-config"
  },
  "files": [
    "LICENCE-expo.txt",
    "src"
  ],
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo --declaration --emitDeclarationOnly --allowJs --outDir types"
  },
  "dependencies": {
    "@expo/config": "catalog:expo-latest",
    "@expo/config-plugins": "catalog:expo-latest",
    "@expo/prebuild-config": "catalog:expo-latest",
    "expo-desktop-config-plugins": "workspace:^1.1.33"
  },
  "devDependencies": {
    "@tsconfig/node24": "catalog:base",
    "@types/node": "catalog:base",
    "@typescript/native-preview": "catalog:base"
  }
}
