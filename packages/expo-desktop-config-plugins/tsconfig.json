{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "types": ["node"],
    "typeRoots": ["node_modules/@types", "typeRoot"],
    "noEmit": false,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true
  },
  "include": ["app.plugin.js", "src"]
}
